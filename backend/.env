# Local backend runtime configuration for development.
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
DATABASE_URL="postgresql://postgres:1234@localhost:5432/safnam_restaurant?schema=public"
JWT_ACCESS_SECRET="change-this-access-secret-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=safnam_refresh_token
BCRYPT_SALT_ROUNDS=12
STORAGE_PROVIDER=local
UPLOAD_BASE_PATH=uploads
UPLOAD_PUBLIC_PATH=/uploads
MAX_IMAGE_SIZE_BYTES=2097152
