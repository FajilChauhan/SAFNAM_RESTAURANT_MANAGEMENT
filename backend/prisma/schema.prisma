// Prisma schema for SAFNAM Restaurant core setup and authentication data.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  RECEPTION
  KITCHEN
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum FloorStatus {
  ACTIVE
  INACTIVE
}

enum TableShape {
  SQUARE
  RECTANGLE
  ROUND
  OVAL
}

enum TableStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  BILLING
  CLEANING
  OUT_OF_SERVICE
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  CLEANING
  OUT_OF_SERVICE
}

enum BookingType {
  TABLE
  ROOM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  CUSTOMER_APP
  RECEPTION
  ADMIN
}

enum MenuEntityStatus {
  ACTIVE
  INACTIVE
}

enum FoodType {
  VEG
  NON_VEG
}

enum SpicyLevel {
  NONE
  MILD
  MEDIUM
  HOT
  EXTRA_HOT
}

enum MenuAvailabilityType {
  BREAKFAST
  LUNCH
  DINNER
  WHOLE_DAY
  CUSTOM_TIME
}

enum CartStatus {
  ACTIVE
  CONFIRMED
  CLEARED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum OrderSource {
  CUSTOMER_APP
  MANAGER
  RECEPTION
}

enum KitchenQueueStatus {
  WAITING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  fullName      String         @db.VarChar(120)
  phoneNumber   String         @unique @db.VarChar(20)
  email         String?        @unique @db.VarChar(255)
  passwordHash  String         @db.VarChar(255)
  role          UserRole       @default(CUSTOMER)
  status        UserStatus     @default(ACTIVE)
  avatarUrl     String?        @db.VarChar(500)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  createdBy     String?        @db.Uuid
  updatedBy     String?        @db.Uuid
  refreshTokens RefreshToken[]
  bookings      Booking[]
  cartItems     CartItem[]
  orders        Order[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String    @unique @db.VarChar(255)
  deviceName       String?   @db.VarChar(120)
  ipAddress        String?   @db.VarChar(45)
  userAgent        String?   @db.Text
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdBy        String?   @db.Uuid
  updatedBy        String?   @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([deletedAt])
  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model Restaurant {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(150)
  logoUrl     String?        @db.VarChar(500)
  description String?        @db.Text
  phone       String         @db.VarChar(20)
  email       String?        @db.VarChar(255)
  address     String         @db.Text
  openingTime String         @db.VarChar(5)
  closingTime String         @db.VarChar(5)
  gstNumber   String?        @db.VarChar(30)
  currency    String         @default("INR") @db.VarChar(3)
  timezone    String         @default("Asia/Kolkata") @db.VarChar(80)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  createdBy   String?        @db.Uuid
  updatedBy   String?        @db.Uuid
  floors      Floor[]
  rooms       Room[]
  categories  MenuCategory[]

  @@index([name])
  @@index([phone])
  @@index([deletedAt])
  @@map("restaurants")
}

model Floor {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @db.Uuid
  name         String        @db.VarChar(100)
  displayOrder Int           @default(0)
  description  String?       @db.Text
  status       FloorStatus   @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  createdBy    String?       @db.Uuid
  updatedBy    String?       @db.Uuid
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       DiningTable[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([status])
  @@index([displayOrder])
  @@index([deletedAt])
  @@map("floors")
}

model DiningTable {
  id          String      @id @default(uuid()) @db.Uuid
  floorId     String      @db.Uuid
  tableNumber String      @unique @db.VarChar(30)
  capacity    Int
  shape       TableShape
  status      TableStatus @default(AVAILABLE)
  qrCodeUrl   String?     @db.VarChar(500)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  createdBy   String?     @db.Uuid
  updatedBy   String?     @db.Uuid
  floor       Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([floorId])
  @@index([status])
  @@index([capacity])
  @@index([deletedAt])
  @@map("tables")
}

model Room {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid
  roomNumber   String     @unique @db.VarChar(30)
  roomType     String     @db.VarChar(80)
  capacity     Int
  pricePerDay  Decimal    @db.Decimal(10, 2)
  description  String?    @db.Text
  status       RoomStatus @default(AVAILABLE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  createdBy    String?    @db.Uuid
  updatedBy    String?    @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([restaurantId])
  @@index([status])
  @@index([roomType])
  @@index([deletedAt])
  @@map("rooms")
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  bookingNumber String        @unique @db.VarChar(40)
  customerId    String        @db.Uuid
  bookingType   BookingType
  tableId       String?       @db.Uuid
  roomId        String?       @db.Uuid
  bookingDate   DateTime      @db.Date
  startTime     String        @db.VarChar(5)
  endTime       String        @db.VarChar(5)
  startAt       DateTime
  endAt         DateTime
  members       Int
  notes         String?       @db.Text
  status        BookingStatus @default(PENDING)
  source        BookingSource
  cancelledAt   DateTime?
  checkedInAt   DateTime?
  checkedOutAt  DateTime?
  noShowAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  createdBy     String?       @db.Uuid
  updatedBy     String?       @db.Uuid
  customer      User          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  table         DiningTable?  @relation(fields: [tableId], references: [id], onDelete: Restrict)
  room          Room?         @relation(fields: [roomId], references: [id], onDelete: Restrict)
  carts         Cart[]
  orders        Order[]

  @@index([customerId])
  @@index([bookingType])
  @@index([status])
  @@index([source])
  @@index([bookingDate])
  @@index([startAt, endAt])
  @@index([tableId, startAt, endAt])
  @@index([roomId, startAt, endAt])
  @@index([deletedAt])
  @@map("bookings")
}

model MenuCategory {
  id           String           @id @default(uuid()) @db.Uuid
  restaurantId String           @db.Uuid
  name         String           @db.VarChar(100)
  description  String?          @db.Text
  displayOrder Int              @default(0)
  status       MenuEntityStatus @default(ACTIVE)
  imageUrl     String?          @db.VarChar(500)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  createdBy    String?          @db.Uuid
  updatedBy    String?          @db.Uuid
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([status])
  @@index([displayOrder])
  @@index([deletedAt])
  @@map("menu_categories")
}

model MenuItem {
  id                 String             @id @default(uuid()) @db.Uuid
  categoryId         String             @db.Uuid
  name               String             @db.VarChar(150)
  description        String?            @db.Text
  price              Decimal            @db.Decimal(10, 2)
  preparationTimeMin Int
  imageUrl           String?            @db.VarChar(500)
  foodType           FoodType
  spicyLevel         SpicyLevel         @default(NONE)
  status             MenuEntityStatus   @default(ACTIVE)
  isTodaySpecial     Boolean            @default(false)
  isAvailable        Boolean            @default(true)
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdBy          String?            @db.Uuid
  updatedBy          String?            @db.Uuid
  category           MenuCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants           MenuItemVariant[]
  addOns             MenuItemAddOn[]
  availability       MenuAvailability[]
  cartItems          CartItem[]
  orderItems         OrderItem[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([status])
  @@index([isTodaySpecial])
  @@index([isAvailable])
  @@index([deletedAt])
  @@map("menu_items")
}

model MenuItemVariant {
  id              String           @id @default(uuid()) @db.Uuid
  menuItemId      String           @db.Uuid
  name            String           @db.VarChar(80)
  priceDifference Decimal          @default(0) @db.Decimal(10, 2)
  status          MenuEntityStatus @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  createdBy       String?          @db.Uuid
  updatedBy       String?          @db.Uuid
  menuItem        MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@unique([menuItemId, name])
  @@index([menuItemId])
  @@index([status])
  @@index([deletedAt])
  @@map("menu_item_variants")
}

model MenuItemAddOn {
  id              String           @id @default(uuid()) @db.Uuid
  menuItemId      String           @db.Uuid
  name            String           @db.VarChar(80)
  additionalPrice Decimal          @db.Decimal(10, 2)
  status          MenuEntityStatus @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  createdBy       String?          @db.Uuid
  updatedBy       String?          @db.Uuid
  menuItem        MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  cartAddOns      CartItemAddOn[]
  orderAddOns     OrderItemAddOn[]

  @@unique([menuItemId, name])
  @@index([menuItemId])
  @@index([status])
  @@index([deletedAt])
  @@map("menu_item_addons")
}

model MenuAvailability {
  id         String               @id @default(uuid()) @db.Uuid
  menuItemId String               @db.Uuid
  type       MenuAvailabilityType
  startTime  String?              @db.VarChar(5)
  endTime    String?              @db.VarChar(5)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  deletedAt  DateTime?
  createdBy  String?              @db.Uuid
  updatedBy  String?              @db.Uuid
  menuItem   MenuItem             @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([type])
  @@index([deletedAt])
  @@map("menu_availability")
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  bookingId String     @db.Uuid
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  createdBy String?    @db.Uuid
  updatedBy String?    @db.Uuid
  booking   Booking    @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  items     CartItem[]
  order     Order?

  @@index([bookingId])
  @@index([status])
  @@index([deletedAt])
  @@map("carts")
}

model CartItem {
  id                   String           @id @default(uuid()) @db.Uuid
  cartId               String           @db.Uuid
  menuItemId           String           @db.Uuid
  variantId            String?          @db.Uuid
  quantity             Int
  unitPriceSnapshot    Decimal          @db.Decimal(10, 2)
  variantPriceSnapshot Decimal          @default(0) @db.Decimal(10, 2)
  discountSnapshot     Decimal          @default(0) @db.Decimal(10, 2)
  lineTotalSnapshot    Decimal          @db.Decimal(10, 2)
  specialNotes         String?          @db.Text
  orderedById          String           @db.Uuid
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  createdBy            String?          @db.Uuid
  updatedBy            String?          @db.Uuid
  cart                 Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem             MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  variant              MenuItemVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  orderedBy            User             @relation(fields: [orderedById], references: [id], onDelete: Restrict)
  addOns               CartItemAddOn[]

  @@index([cartId])
  @@index([menuItemId])
  @@index([variantId])
  @@index([orderedById])
  @@index([deletedAt])
  @@map("cart_items")
}

model CartItemAddOn {
  id            String        @id @default(uuid()) @db.Uuid
  cartItemId    String        @db.Uuid
  addOnId       String        @db.Uuid
  priceSnapshot Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  createdBy     String?       @db.Uuid
  updatedBy     String?       @db.Uuid
  cartItem      CartItem      @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  addOn         MenuItemAddOn @relation(fields: [addOnId], references: [id], onDelete: Restrict)

  @@unique([cartItemId, addOnId])
  @@index([cartItemId])
  @@index([addOnId])
  @@index([deletedAt])
  @@map("cart_item_addons")
}

model Order {
  id               String        @id @default(uuid()) @db.Uuid
  orderNumber      String        @unique @db.VarChar(40)
  bookingId        String        @db.Uuid
  cartId           String        @unique @db.Uuid
  orderedById      String        @db.Uuid
  status           OrderStatus   @default(CONFIRMED)
  source           OrderSource
  subtotalSnapshot Decimal       @db.Decimal(10, 2)
  discountSnapshot Decimal       @default(0) @db.Decimal(10, 2)
  totalSnapshot    Decimal       @db.Decimal(10, 2)
  confirmedAt      DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  createdBy        String?       @db.Uuid
  updatedBy        String?       @db.Uuid
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  cart             Cart          @relation(fields: [cartId], references: [id], onDelete: Restrict)
  orderedBy        User          @relation(fields: [orderedById], references: [id], onDelete: Restrict)
  items            OrderItem[]
  kitchenQueue     KitchenQueue?

  @@index([bookingId])
  @@index([orderedById])
  @@index([status])
  @@index([source])
  @@index([confirmedAt])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id                   String           @id @default(uuid()) @db.Uuid
  orderId              String           @db.Uuid
  menuItemId           String           @db.Uuid
  variantId            String?          @db.Uuid
  itemNameSnapshot     String           @db.VarChar(150)
  variantNameSnapshot  String?          @db.VarChar(80)
  quantity             Int
  unitPriceSnapshot    Decimal          @db.Decimal(10, 2)
  variantPriceSnapshot Decimal          @default(0) @db.Decimal(10, 2)
  discountSnapshot     Decimal          @default(0) @db.Decimal(10, 2)
  lineTotalSnapshot    Decimal          @db.Decimal(10, 2)
  specialNotes         String?          @db.Text
  orderedById          String           @db.Uuid
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  createdBy            String?          @db.Uuid
  updatedBy            String?          @db.Uuid
  order                Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem             MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  variant              MenuItemVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  addOns               OrderItemAddOn[]

  @@index([orderId])
  @@index([menuItemId])
  @@index([variantId])
  @@index([orderedById])
  @@index([deletedAt])
  @@map("order_items")
}

model OrderItemAddOn {
  id            String        @id @default(uuid()) @db.Uuid
  orderItemId   String        @db.Uuid
  addOnId       String        @db.Uuid
  nameSnapshot  String        @db.VarChar(80)
  priceSnapshot Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  createdBy     String?       @db.Uuid
  updatedBy     String?       @db.Uuid
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addOn         MenuItemAddOn @relation(fields: [addOnId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([addOnId])
  @@index([deletedAt])
  @@map("order_item_addons")
}

model KitchenQueue {
  id        String             @id @default(uuid()) @db.Uuid
  orderId   String             @unique @db.Uuid
  status    KitchenQueueStatus @default(WAITING)
  queuedAt  DateTime           @default(now())
  startedAt DateTime?
  readyAt   DateTime?
  servedAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  createdBy String?            @db.Uuid
  updatedBy String?            @db.Uuid
  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([queuedAt])
  @@index([deletedAt])
  @@map("kitchen_queue")
}
