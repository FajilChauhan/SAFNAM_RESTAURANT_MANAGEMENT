# This file documents required environment variables without storing secrets.
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
DATABASE_URL="postgresql://postgres:Your_Password@localhost:5432/Your_Database?schema=public"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=safnam_refresh_token
BCRYPT_SALT_ROUNDS=12
STORAGE_PROVIDER=local
UPLOAD_BASE_PATH=uploads
UPLOAD_PUBLIC_PATH=/uploads
MAX_IMAGE_SIZE_BYTES=2097152
